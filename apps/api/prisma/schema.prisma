// mars-ari-lms — Prisma schema
// PostgreSQL with full multi-tenant, ACL, audit support

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, pg_trgm]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  TENANT_ADMIN
  INSTRUCTOR
  STUDENT
  GUEST
}

enum CourseStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum ContentType {
  TEXT
  VIDEO
  QUIZ
  CODE_SANDBOX
  EMBED
  SLIDE_DECK
  LAB // external lab integration
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  SUSPENDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum WebhookEvent {
  COURSE_ENROLLED
  LESSON_COMPLETED
  COURSE_COMPLETED
  QUIZ_PASSED
  QUIZ_FAILED
  CERTIFICATE_ISSUED
  PAYMENT_SUCCEEDED
  PAYMENT_FAILED
}

enum IntegrationType {
  WEBHOOK
  SDK
  LINK
}

enum LLMProvider {
  OPENAI
  ANTHROPIC
  GOOGLE
  OLLAMA
  GROQ
  MISTRAL
  CUSTOM // any OpenAI-compatible endpoint
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

// ─── Tenant (multi-tenant white-label) ───────────────────────────────────────

model Tenant {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug          String   @unique @db.VarChar(63)
  name          String
  domain        String?  @unique
  logoUrl       String?
  primaryColor  String?  @db.VarChar(7)
  accentColor   String?  @db.VarChar(7)
  faviconUrl    String?
  customCss     String?
  isActive      Boolean  @default(true)
  planTier      String   @default("free") // free | pro | enterprise
  stripeCustomerId String? @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  courses       Course[]
  integrations  Integration[]
  webhooks      Webhook[]
  aiConfigs     TenantAIConfig[]
  invoices      Invoice[]
  auditLogs     AuditLog[]

  @@index([slug])
  @@index([domain])
}

// ─── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  keycloakId    String   @unique
  tenantId      String   @db.Uuid
  email         String
  displayName   String
  avatarUrl     String?
  role          Role     @default(STUDENT)
  bio           String?
  timezone      String   @default("UTC")
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enrollments   Enrollment[]
  courseAuthors CourseAuthor[]
  quizAttempts  QuizAttempt[]
  certificates  Certificate[]
  auditLogs     AuditLog[]
  apiKeys       ApiKey[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([keycloakId])
}

model ApiKey {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  name        String
  keyHash     String   @unique
  prefix      String   @db.VarChar(8) // shown to user for identification
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Course Structure ─────────────────────────────────────────────────────────

model Course {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String       @db.Uuid
  slug          String
  title         String
  description   String?
  thumbnailUrl  String?
  status        CourseStatus @default(DRAFT)
  price         Decimal?     @db.Decimal(10, 2)
  currency      String       @default("usd") @db.VarChar(3)
  isFree        Boolean      @default(false)
  tags          String[]
  level         String?      // beginner | intermediate | advanced
  language      String       @default("en") @db.VarChar(10)
  estimatedHours Int?
  prerequisites String[]
  objectives    String[]
  version       Int          @default(1)
  publishedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  authors       CourseAuthor[]
  modules       Module[]
  enrollments   Enrollment[]
  certificates  Certificate[]
  aiJobs        AICopilotJob[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([status])
}

model CourseAuthor {
  courseId  String  @db.Uuid
  userId    String  @db.Uuid
  role      String  @default("author") // author | co-author | reviewer

  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([courseId, userId])
}

model Module {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId    String   @db.Uuid
  title       String
  description String?
  position    Int
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  progress    ModuleProgress[]

  @@index([courseId, position])
}

model Lesson {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  moduleId      String      @db.Uuid
  title         String
  contentType   ContentType @default(TEXT)
  content       Json?       // flexible content block (prose, code, embed config)
  videoUrl      String?
  videoDuration Int?        // seconds
  position      Int
  isPublished   Boolean     @default(false)
  isFree        Boolean     @default(false) // preview lesson
  estimatedMinutes Int?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  module        Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress      LessonProgress[]
  quiz          Quiz?
  labConfig     LabConfig?
  media         LessonMedia[]

  @@index([moduleId, position])
}

model LessonMedia {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId  String   @db.Uuid
  type      String   // image | video | document | slide
  url       String
  mimeType  String?
  sizeBytes Int?
  alt       String?
  position  Int      @default(0)
  createdAt DateTime @default(now())

  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// ─── Assessments ──────────────────────────────────────────────────────────────

model Quiz {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId      String      @unique @db.Uuid
  title         String
  passingScore  Int         @default(70) // percentage
  maxAttempts   Int?
  timeLimit     Int?        // seconds
  randomize     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  lesson        Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions     Question[]
  attempts      QuizAttempt[]
}

model Question {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quizId    String   @db.Uuid
  text      String
  type      String   // multiple_choice | true_false | short_answer | code
  options   Json?    // [{id, text}]
  answer    Json     // correct answer(s)
  points    Int      @default(1)
  explanation String?
  position  Int

  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizAttempt {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quizId      String   @db.Uuid
  userId      String   @db.Uuid
  answers     Json     // {questionId: answer}
  score       Int
  passed      Boolean
  startedAt   DateTime @default(now())
  completedAt DateTime?

  quiz        Quiz     @relation(fields: [quizId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([quizId, userId])
}

// ─── Lab Integration ──────────────────────────────────────────────────────────

model LabConfig {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lessonId      String          @unique @db.Uuid
  integrationId String          @db.Uuid
  launchUrl     String?         // direct link
  sdkConfig     Json?           // SDK params passed on launch
  webhookEvents WebhookEvent[]  // events this lab reports back
  metadata      Json?

  lesson        Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  integration   Integration     @relation(fields: [integrationId], references: [id])
}

// ─── Progress & Enrollment ────────────────────────────────────────────────────

model Enrollment {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String           @db.Uuid
  courseId    String           @db.Uuid
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  invoiceId   String?          @db.Uuid

  user        User             @relation(fields: [userId], references: [id])
  course      Course           @relation(fields: [courseId], references: [id])
  invoice     Invoice?         @relation(fields: [invoiceId], references: [id])
  lessonProgress LessonProgress[]
  moduleProgress ModuleProgress[]
  certificate Certificate?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  enrollmentId String   @db.Uuid
  lessonId     String   @db.Uuid
  completedAt  DateTime @default(now())
  timeSpent    Int?     // seconds

  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson       Lesson     @relation(fields: [lessonId], references: [id])

  @@id([enrollmentId, lessonId])
}

model ModuleProgress {
  enrollmentId String   @db.Uuid
  moduleId     String   @db.Uuid
  completedAt  DateTime @default(now())

  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  module       Module     @relation(fields: [moduleId], references: [id])

  @@id([enrollmentId, moduleId])
}

// ─── Certificates ────────────────────────────────────────────────────────────

model Certificate {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId String   @unique @db.Uuid
  userId       String   @db.Uuid
  courseId     String   @db.Uuid
  pdfUrl       String?
  verifyToken  String   @unique @default(dbgenerated("gen_random_uuid()"))
  issuedAt     DateTime @default(now())

  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  course       Course     @relation(fields: [courseId], references: [id])
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Invoice {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String        @db.Uuid
  stripePaymentIntentId String?   @unique
  amount            Decimal       @db.Decimal(10, 2)
  currency          String        @db.VarChar(3)
  status            PaymentStatus @default(PENDING)
  metadata          Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant            Tenant        @relation(fields: [tenantId], references: [id])
  enrollments       Enrollment[]
}

// ─── Integrations (link / SDK / webhook) ─────────────────────────────────────

model Integration {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String          @db.Uuid
  name        String
  description String?
  type        IntegrationType
  // LINK: just a URL opened in new tab / iframe
  linkUrl     String?
  linkTarget  String?         @default("_blank") // _blank | iframe
  // SDK: JS SDK config injected into lesson
  sdkPackage  String?         // npm package name
  sdkConfig   Json?
  // WEBHOOK: outbound POST on events
  webhookUrl  String?
  webhookSecret String?
  webhookEvents WebhookEvent[]
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  labConfigs  LabConfig[]
  webhookLogs WebhookLog[]

  @@index([tenantId])
}

model Webhook {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String       @db.Uuid
  event       WebhookEvent
  payload     Json
  status      Int          @default(0) // HTTP status of delivery
  attempts    Int          @default(0)
  nextRetryAt DateTime?
  deliveredAt DateTime?
  createdAt   DateTime     @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, event])
}

model WebhookLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  integrationId String   @db.Uuid
  event         WebhookEvent
  payload       Json
  responseStatus Int?
  responseBody  String?
  durationMs    Int?
  createdAt     DateTime @default(now())

  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
}

// ─── AI Copilot ───────────────────────────────────────────────────────────────

model TenantAIConfig {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String      @db.Uuid
  provider    LLMProvider
  model       String      // e.g. gpt-4o, claude-opus-4-6, gemini-2.0-flash
  apiKey      String?     // encrypted at rest
  baseUrl     String?     // for custom/Ollama endpoints
  isDefault   Boolean     @default(false)
  temperature Float?      @default(0.7)
  maxTokens   Int?        @default(4096)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
}

model AICopilotJob {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId    String    @db.Uuid
  jobType     String    // generate_curriculum | generate_lesson | generate_quiz | enrich_media
  prompt      String
  provider    LLMProvider
  model       String
  status      JobStatus @default(PENDING)
  result      Json?
  error       String?
  tokensUsed  Int?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([status])
}

// ─── Audit & Logging ──────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @db.Uuid
  userId     String?  @db.Uuid
  action     String   // e.g. course.publish, user.role_change
  resource   String   // table/entity name
  resourceId String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([resource, resourceId])
}
