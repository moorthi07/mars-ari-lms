# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=marsari
POSTGRES_PASSWORD=marsari_secret
POSTGRES_DB=mars_ari_lms
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379

# ── OpenSearch ───────────────────────────────────────────────────────────────
OPENSEARCH_ADMIN_PASSWORD=Admin_Secret_123
OPENSEARCH_PORT=9200

# ── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret
KEYCLOAK_PORT=8080
KEYCLOAK_REALM=mars-ari
KEYCLOAK_CLIENT_ID=mars-ari-api
KEYCLOAK_CLIENT_SECRET=changeme
KC_HOSTNAME=localhost
VITE_KEYCLOAK_CLIENT_ID=mars-ari-web

# ── MinIO (S3-compatible media storage) ──────────────────────────────────────
MINIO_ROOT_USER=mars_ari_minio
MINIO_ROOT_PASSWORD=minio_secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=mars-ari-media

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AI Providers (BYOK — leave empty to disable) ─────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
GROQ_API_KEY=
# For local Ollama — set to your machine's LAN IP if running outside Docker
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── YouTube Data API (for video search in AI Copilot) ────────────────────────
YOUTUBE_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
JWT_SECRET=changeme_in_production_use_32+_chars
API_PORT=3001
WEB_PORT=3000
VITE_API_URL=http://localhost:3001
VITE_KEYCLOAK_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:3000
